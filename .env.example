# Copy to .env and fill in real values. Never commit .env.

# Database
DB_HOST=your-mysql-host
DB_USER=your_user
DB_PASS=your_password
DB_NAME=your_database
# Optional; default 3306 (see env_loader.php)
# DB_PORT=3306

# SMTP — Gmail: 465 + ssl, or 587 + tls (set SMTP_ENCRYPTION=tls)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Your App Name

# Google APIs (keys from Google Cloud / AI Studio)
GOOGLE_VISION_API_URL=https://vision.googleapis.com/v1/images:annotate
GOOGLE_VISION_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1/models/gemini-1.5-flash:generateContent
GEMINI_API_KEY=

# census_form.census_id must match resident_information.id using the same rules:
# legacy = numeric string ("10") for older INT columns
# prefixed = CEN-001 style (VARCHAR), from id + prefix + zero-pad
CENSUS_ID_MODE=prefixed
CENSUS_ID_PREFIX=CEN
CENSUS_ID_PAD=3
